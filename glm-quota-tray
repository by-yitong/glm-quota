#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
智谱 GLM Coding Plan 用量 —— KDE 系统托盘常驻应用。

功能：
  - 任务栏托盘图标直接显示当前 5 小时窗口已用百分比（如 "73%"）
  - 颜色随用量变化：<60% 绿 / 60-85% 橙 / >85% 红 / 错误灰
  - 右键菜单：详情、立即刷新、退出
  - 左键点击：刷新
  - 可选定时自动刷新 + 超阈值桌面通知
  - 网络请求在 QThread 后台线程，不卡 UI
  - 失败时保留上次成功值，图标标 ERR

依赖：PyQt6 + glm_quota_core.py（同目录的 share 下）
"""

import os
import sys
import subprocess
from datetime import datetime

sys.path.insert(0, os.path.expanduser("~/.local/share/glm-quota"))
import glm_quota_core as core  # noqa: E402

from PyQt6.QtCore import Qt, QTimer, QThread, pyqtSignal
from PyQt6.QtGui import QIcon, QPixmap, QPainter, QColor, QFont, QAction
from PyQt6.QtWidgets import (
    QApplication, QSystemTrayIcon, QMenu, QMessageBox,
    QDialog, QFormLayout, QLineEdit, QComboBox, QSpinBox, QCheckBox,
    QDialogButtonBox, QLabel, QHBoxLayout,
)

# 开机自启的 desktop 文件路径
AUTOSTART_DIR = os.path.expanduser("~/.config/autostart")
AUTOSTART_PATH = os.path.join(AUTOSTART_DIR, "glm-quota-tray.desktop")
# 自启 desktop 内容（Exec 指向本脚本绝对路径）
SCRIPT_PATH = os.path.realpath(__file__)
AUTOSTART_DESKTOP = """[Desktop Entry]
Type=Application
Name=GLM Coding Plan 用量监控
Comment=系统托盘常驻显示智谱 GLM Coding Plan 用量
Exec={script}
Icon=utilities-system-monitor
Terminal=false
X-GNOME-Autostart-enabled=true
X-KDE-autostart-after=panel
StartupNotify=false
"""


def autostart_enabled() -> bool:
    """检查是否已配置开机自启。"""
    return os.path.isfile(AUTOSTART_PATH)


def set_autostart(enabled: bool) -> None:
    """启用/禁用开机自启（写/删 desktop 文件）。"""
    if enabled:
        os.makedirs(AUTOSTART_DIR, exist_ok=True)
        with open(AUTOSTART_PATH, "w", encoding="utf-8") as f:
            f.write(AUTOSTART_DESKTOP.format(script=SCRIPT_PATH))
    else:
        try:
            os.remove(AUTOSTART_PATH)
        except FileNotFoundError:
            pass


# 用量阈值颜色（绿/橙/红）
def _color_for_pct(pct):
    if pct is None:
        return QColor(150, 150, 150)  # 灰：无数据
    if pct >= 85:
        return QColor(232, 80, 80)    # 红
    if pct >= 60:
        return QColor(230, 160, 50)   # 橙
    return QColor(70, 180, 90)        # 绿


def _make_icon_text(pct):
    """图标上显示的短文字。"""
    if pct is None:
        return "?"
    return "%d%%" % round(pct)


def _make_icon(pct, errored=False):
    """生成带文字的图标。

    用高分辨率源图绘制，再注册多尺寸(32/48/64)供托盘容器按需缩放，
    避免小尺寸渲染时文字糊/虚。文字字号随尺寸自适应、占比更大更醒目。
    """
    # 各显示尺寸对应的目标像素字号
    SIZES = (32, 48, 64)

    if errored:
        bg = QColor(180, 60, 60)
        text_color = QColor(255, 255, 255)
        text = "ERR"
    else:
        bg = _color_for_pct(pct)
        text_color = QColor(255, 255, 255)
        text = _make_icon_text(pct)

    icon = QIcon()
    for size in SIZES:
        # 文字字号：取显示尺寸的较大比例，让百分比醒目
        if len(text) <= 3:        # 如 "73%"
            font_px = int(size * 0.40)
        else:                     # 如 "ERR" / "120%"
            font_px = int(size * 0.28)

        pm = QPixmap(size, size)
        pm.fill(Qt.GlobalColor.transparent)
        p = QPainter(pm)
        p.setRenderHint(QPainter.RenderHint.Antialiasing, True)
        p.setRenderHint(QPainter.RenderHint.TextAntialiasing, True)
        p.setRenderHint(QPainter.RenderHint.SmoothPixmapTransform, True)

        # 圆角背景
        p.setBrush(bg)
        p.setPen(Qt.PenStyle.NoPen)
        r = max(4, size * 0.2)
        p.drawRoundedRect(0, 0, size, size, r, r)

        # 文字
        p.setPen(text_color)
        font = QFont()
        font.setBold(True)
        font.setPixelSize(font_px)
        p.setFont(font)
        p.drawText(pm.rect(), Qt.AlignmentFlag.AlignCenter, text)
        p.end()
        icon.addPixmap(pm, QIcon.Mode.Normal, QIcon.State.Off)
    return icon


def _fmt_local(iso):
    if not iso:
        return "—"
    try:
        dt = datetime.fromisoformat(iso)
        return dt.astimezone().strftime("%m-%d %H:%M")
    except Exception:
        return str(iso)


def _fmt_queried_at(ms):
    """毫秒时间戳 → 本地时间字符串（最近一次成功刷新接口的时刻）。"""
    if not ms:
        return "—"
    try:
        from datetime import timezone
        dt = datetime.fromtimestamp(ms / 1000, tz=timezone.utc).astimezone()
        return dt.strftime("%Y-%m-%d %H:%M:%S")
    except Exception:
        return str(ms)


class ConfigDialog(QDialog):
    """可视化配置对话框：表单编辑 api_key / base_url / 刷新间隔 / 通知阈值。

    api_key 用密码模式输入框，右侧带"显示/隐藏"切换按钮，避免肩窥；
    其余字段用下拉/数字框，防止格式错误。确定即写回 config.json(权限600)。
    """

    BASE_URLS = [
        ("中国站 open.bigmodel.cn", "https://open.bigmodel.cn"),
        ("国际站 api.z.ai", "https://api.z.ai"),
    ]

    def __init__(self, cfg, parent=None):
        super().__init__(parent)
        self.setWindowTitle("智谱 Coding Plan — 配置")
        self.setMinimumWidth(460)
        self._cfg = dict(cfg)  # 不直接改原 dict，取消时不影响

        form = QFormLayout(self)
        form.setSpacing(10)

        # api_key：密码模式 + 显示切换
        self.key_edit = QLineEdit(self._cfg.get("api_key", ""))
        self.key_edit.setEchoMode(QLineEdit.EchoMode.Password)
        self.key_edit.setPlaceholderText("在此填入智谱 api_key")
        key_row = QHBoxLayout()
        key_row.setContentsMargins(0, 0, 0, 0)
        key_row.addWidget(self.key_edit)
        self.show_key_btn = QAction("显示", self)
        # 用带 checkable 的按钮做显示/隐藏
        from PyQt6.QtWidgets import QToolButton
        self.toggle_btn = QToolButton(checkable=True, text="显示")
        self.toggle_btn.setToolButtonStyle(Qt.ToolButtonStyle.ToolButtonTextOnly)
        self.toggle_btn.toggled.connect(self._toggle_key_visible)
        key_row.addWidget(self.toggle_btn)
        from PyQt6.QtWidgets import QWidget
        key_wrap = QWidget()
        key_wrap.setLayout(key_row)
        form.addRow("API Key:", key_wrap)

        # base_url：下拉，但若现有值不在列表里则追加一项
        self.url_combo = QComboBox()
        cur_url = self._cfg.get("base_url", "https://open.bigmodel.cn")
        for label, val in self.BASE_URLS:
            self.url_combo.addItem(label, val)
        if cur_url not in [v for _, v in self.BASE_URLS]:
            self.url_combo.addItem(cur_url, cur_url)
        self.url_combo.setCurrentIndex(self.url_combo.findData(cur_url))
        form.addRow("接口站点:", self.url_combo)

        # 自动刷新间隔
        self.refresh_spin = QSpinBox()
        self.refresh_spin.setRange(0, 1440)
        self.refresh_spin.setSuffix(" 分钟")
        self.refresh_spin.setSpecialValueText("关闭自动刷新")
        self.refresh_spin.setValue(int(self._cfg.get("refresh_minutes", 30)))
        form.addRow("自动刷新:", self.refresh_spin)

        # 通知阈值
        self.notify_spin = QSpinBox()
        self.notify_spin.setRange(0, 100)
        self.notify_spin.setSuffix(" %")
        self.notify_spin.setSpecialValueText("关闭通知")
        self.notify_spin.setValue(int(self._cfg.get("notify_threshold", 85)))
        form.addRow("超量提醒阈值:", self.notify_spin)

        # 开机自启开关
        self.autostart_check = QCheckBox("登录桌面时自动启动托盘")
        self.autostart_check.setChecked(autostart_enabled())
        form.addRow("开机自启:", self.autostart_check)

        hint = QLabel("提示：api_key 仅保存在本机配置文件(权限 600)，不会上传任何地方。\n"
                      "国内站(bigmodel.cn)与国际站(z.ai)的 key 不通用。")
        hint.setWordWrap(True)
        hint.setStyleSheet("color: gray; font-size: 11px;")
        form.addRow(hint)

        # 确定/取消
        buttons = QDialogButtonBox(
            QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        buttons.accepted.connect(self.accept)
        buttons.rejected.connect(self.reject)
        form.addRow(buttons)

    def _toggle_key_visible(self, checked):
        if checked:
            self.key_edit.setEchoMode(QLineEdit.EchoMode.Normal)
            self.toggle_btn.setText("隐藏")
        else:
            self.key_edit.setEchoMode(QLineEdit.EchoMode.Password)
            self.toggle_btn.setText("显示")

    def values(self):
        """返回填好的配置 dict。"""
        return {
            "api_key": self.key_edit.text().strip(),
            "base_url": self.url_combo.currentData(),
            "refresh_minutes": self.refresh_spin.value(),
            "notify_threshold": self.notify_spin.value(),
        }


class QueryWorker(QThread):
    """后台查询线程，避免阻塞 UI。"""
    finished = pyqtSignal(object)  # 发 QuotaResult

    def __init__(self, api_key, base_url):
        super().__init__()
        self.api_key = api_key
        self.base_url = base_url

    def run(self):
        try:
            result = core.query_quota(self.api_key, self.base_url)
        except Exception as e:
            result = core.QuotaResult(ok=False, error="异常: %s" % e,
                                      credential_valid=True,
                                      queried_at=core._now_millis())
        self.finished.emit(result)


class TrayApp:
    def __init__(self):
        self.cfg = core.load_config()
        self.last_result = None        # 上次成功的 QuotaResult（用于失败时保留展示）
        self.worker = None             # 当前查询线程
        self.last_notified_pct = None  # 防止通知风暴

        self.app = QApplication.instance() or QApplication(sys.argv)
        self.app.setApplicationName("glm-quota-tray")
        self.app.setQuitOnLastWindowClosed(False)

        # 托盘
        self.tray = QSystemTrayIcon(_make_icon(None))
        self.tray.setToolTip("智谱 Coding Plan 用量（点击刷新）")
        self.tray.activated.connect(self._on_activated)

        # 菜单
        menu = QMenu()
        self.act_detail = QAction("用量详情", menu)
        self.act_detail.triggered.connect(self._show_detail)
        menu.addAction(self.act_detail)
        menu.addSeparator()
        act_refresh = QAction("立即刷新", menu)
        act_refresh.triggered.connect(self.refresh)
        menu.addAction(act_refresh)
        act_edit = QAction("配置…", menu)
        act_edit.triggered.connect(self._edit_config)
        menu.addAction(act_edit)
        menu.addSeparator()
        act_quit = QAction("退出", menu)
        act_quit.triggered.connect(self.app.quit)
        menu.addAction(act_quit)
        self.menu = menu
        self.tray.setContextMenu(menu)

        # 定时刷新
        self.timer = QTimer()
        self.timer.timeout.connect(self.refresh)

    # ── 启动 ──────────────────────────────────────────────
    def run(self):
        if not QSystemTrayIcon.isSystemTrayAvailable():
            # 无托盘环境（纯命令行）回退提示
            sys.stderr.write("未检测到系统托盘，无法常驻。请在桌面会话中运行。\n")
            sys.exit(1)
        self.tray.show()

        # 首次启动：若无 key，直接弹配置对话框引导填写
        if not self.cfg.get("api_key"):
            self._update_icon(None, errored=True)
            self.tray.setToolTip("未配置 api_key")
            _notify("智谱用量监控", "首次使用，请填写 api_key")
            self._edit_config()
        else:
            self.refresh()
            self._start_timer()
        sys.exit(self.app.exec())

    def _start_timer(self):
        mins = self.cfg.get("refresh_minutes", 30)
        if mins and mins > 0:
            self.timer.start(int(mins * 60 * 1000))
        else:
            self.timer.stop()

    # ── 交互 ──────────────────────────────────────────────
    def _on_activated(self, reason):
        # 左键 / 单击 → 刷新（中键也行）
        if reason in (QSystemTrayIcon.ActivationReason.Trigger,
                      QSystemTrayIcon.ActivationReason.MiddleClick):
            self.refresh()

    def _edit_config(self):
        """打开可视化配置对话框，确定即写回并立即生效。"""
        dlg = ConfigDialog(self.cfg)
        if dlg.exec() == QDialog.DialogCode.Accepted:
            new_cfg = dlg.values()
            core.save_config(new_cfg)
            self.cfg = new_cfg
            self._start_timer()  # 刷新间隔可能变了
            # 开机自启开关
            set_autostart(dlg.autostart_check.isChecked())
            _notify("智谱用量监控", "配置已保存。")
            self.refresh()       # 立即用新配置查一次

    def _show_detail(self):
        r = self.last_result
        if r is None or not r.ok:
            QMessageBox.information(None, "智谱 Coding Plan 用量",
                                    "暂无数据。\n%s" %
                                    ((r.error if r else "请先刷新"), ))
            return
        lines = ["套餐等级: %s" % (r.level or "未知"), ""]
        if not r.tiers:
            lines.append("（无可用窗口数据）")
        else:
            for t in r.tiers:
                label = {"five_hour": "5小时窗口",
                         "weekly_limit": "每周窗口"}.get(t.name, t.name)
                lines.append("%s：%5.1f%%" % (label, t.utilization))
                lines.append("    重置时间: %s" % _fmt_local(t.resets_at))
        lines += ["", "最近刷新: %s" % _fmt_queried_at(r.queried_at)]
        QMessageBox.information(None, "智谱 Coding Plan 用量", "\n".join(lines))

    # ── 查询 ──────────────────────────────────────────────
    def refresh(self):
        if self.worker is not None and self.worker.isRunning():
            return  # 防止重复并发
        if not self.cfg.get("api_key"):
            self.tray.setToolTip("未配置 api_key，请右键 → 编辑配置")
            return
        self.tray.setToolTip("正在查询…")
        self.worker = QueryWorker(self.cfg["api_key"], self.cfg.get("base_url", "https://api.z.ai"))
        self.worker.finished.connect(self._on_query_done)
        self.worker.start()

    def _on_query_done(self, result):
        # 重载配置（用户可能改了 key/阈值）
        self.cfg = core.load_config()
        self._start_timer()

        if result.ok:
            self.last_result = result
            pct = core.primary_percentage(result)
            self._update_icon(pct, errored=False)
            self._update_tooltip(result, pct)
            self._maybe_notify(pct)
        else:
            # 失败：保留上次成功值展示，但标红 + tooltip 带 error
            pct = core.primary_percentage(self.last_result) if self.last_result else None
            errored = not result.credential_valid  # key 失效才标红
            self._update_icon(pct, errored=errored)
            tip = result.error or "查询失败"
            if self.last_result and self.last_result.ok and not errored:
                tip = "%s（展示为上次成功值）" % tip
            self.tray.setToolTip(tip[:200])

    def _update_icon(self, pct, errored=False):
        self.tray.setIcon(_make_icon(pct, errored=errored))

    def _update_tooltip(self, result, pct):
        parts = ["智谱 Coding Plan"]
        if result.level:
            parts.append("[%s]" % result.level)
        if pct is not None:
            parts.append("5h窗口 %d%%" % round(pct))
        # 周窗口也带上
        wk = core.tier_by_name(result, core.TIER_WEEKLY)
        if wk:
            parts.append("周窗口 %d%%" % round(wk.utilization))
        self.tray.setToolTip(" ".join(parts))

    def _maybe_notify(self, pct):
        thr = self.cfg.get("notify_threshold", 85)
        if not thr or thr <= 0 or pct is None:
            return
        if pct >= thr and self.last_notified_pct is not None and self.last_notified_pct < thr:
            # 仅在跨过阈值时通知一次，避免每次刷新都弹
            _notify("智谱 Coding Plan 用量告警",
                    "5小时窗口已用 %d%%（超过阈值 %d%%）" % (round(pct), thr))
        self.last_notified_pct = pct


def _notify(title, body):
    """桌面通知：优先 notify-send（跨桌面环境），失败回退托盘消息。"""
    try:
        subprocess.run(["notify-send", "--app-name=glm-quota",
                        "--icon=dialog-information", title, body],
                       check=False, timeout=5,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def main():
    app = TrayApp()
    app.run()


if __name__ == "__main__":
    main()
